* text=auto

# Automatically normalize line endings for all text files
*.cs text eol=lf
*.csproj text eol=lf
*.sln text eol=lf
*.slnx text eol=lf
*.xml text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.txt text eol=lf

# Binary files
*.dll binary
*.exe binary
*.so binary
*.dylib binary
